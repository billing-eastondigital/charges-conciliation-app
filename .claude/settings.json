{
  "permissions": {
    "allow": [
      "Bash(python:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(supabase:*)",
      "Bash(git diff:*)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(jq:*)",
      "Bash(sqlite3:*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(supabase db push:*)",
      "Bash(supabase functions deploy:*)",
      "Bash(rm -rf /*)",
      "Bash(curl:*) -X POST",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./supabase/.env)"
    ]
  },
  "env": {
    "PYTHONPATH": "./engine",
    "RECON_DB": "./reconciliation.db"
  }
}
